{
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node", "vite/client"]
  },
  "include": [
    "vite.config.ts",
    "playwright.config.ts",
    "vitest.config.ts",
    "src/config/**/*.ts",
    "src/types/**/*.ts",
    "src/vite-env.d.ts"
  ]
}
